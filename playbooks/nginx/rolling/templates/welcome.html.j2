<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ index_title | default("Jailed Nginx") }}</title>
    <style>
      html, body { height: 100%; margin: 0; }
      body { background: #000; color: #fff; overflow: hidden; }
      img { width: 100%; height: auto; display: block; }
      .wrap {
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }
      .card { width: 92vw; max-width: 896px; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <img src="https://raw.githubusercontent.com/hyphatech/jailrun/main/logo.png" alt="jrun" />
      </div>
    </div>
  </body>
</html>
